PORT=4000
MONGODB_URI=mongodb://localhost:27017/clinic-queue?replicaSet=rs0
# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3001

# Public URLs (password reset links, uploaded file URLs)
FRONTEND_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:4000

# WebSocket uses the same JWT + CORS origin (namespace /realtime)

# SMTP — password reset emails (if unset, dev mode logs token)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@your-clinic.com

# File storage: local | s3
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=uploads

# S3 (when STORAGE_PROVIDER=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Platform admin bootstrap (created on first start if none exists)
PLATFORM_ADMIN_EMAIL=admin@platform.local
PLATFORM_ADMIN_PASSWORD=change-me-in-production

# Optional seed defaults
SEED_CLINIC_NAME=Default Clinic

# Optional SMS (Ethiopia gateway — token alerts when patients join / are called)
# When disabled, messages are logged only (no external API calls).
SMS_ENABLED=false
SMS_API_URL=
SMS_API_KEY=
# SMS message language: en | am | om (default am)
SMS_LOCALE=am

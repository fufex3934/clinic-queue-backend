PORT=4000
MONGODB_URI=mongodb://localhost:27017/clinic-queue
# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3001

# Seed script (pnpm run seed) — clinic admin for first deploy
SEED_ADMIN_EMAIL=admin@clinic.local
SEED_ADMIN_PASSWORD=change-this-password
SEED_CLINIC_NAME=Default Clinic

# Auto-created on startup if no platform_admin exists (idempotent)
PLATFORM_ADMIN_EMAIL=platform@clinic.local
PLATFORM_ADMIN_PASSWORD=change-this-platform-password

# Demo dataset: pnpm run seed:demo (4 clinics, staff, patients, queues, appointments)
# SEED_DEMO_PASSWORD=
# SEED_DEMO_RESET=true pnpm run seed:demo   # wipe demo data and re-insert
